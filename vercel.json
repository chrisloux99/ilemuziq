{
    "version": 2,
    "builds": [
        {
            "src": "src/remote/**/*",
            "use": "@vercel/vite",
            "config": {
                "distDir": "out/remote"
            }
        }
    ],
    "routes": [
        {
            "src": "/remote/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=0, must-revalidate"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/remote/$1"
        }
    ]
}
